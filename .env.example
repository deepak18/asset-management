# =====================================================================
# asset-management — Environment template
# Copy to `.env` and fill in real values. NEVER commit the real `.env`.
# Loaded by backend/app/core/config.py (Pydantic BaseSettings).
# =====================================================================

# ---------- App / Server ----------
APP_ENV=local                     # local | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
# Comma-separated origins allowed to call the API (frontend URL)
CORS_ALLOW_ORIGINS=http://localhost:3000

# ---------- Security ----------
# Secret for signing tokens/sessions. Generate: `openssl rand -hex 32`
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Optional simple gate for local API access (used by core/security.py)
API_ACCESS_KEY=

# ---------- Database (PostgreSQL + pgvector) ----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=asset_management
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Async SQLAlchemy URL (Alembic may use a sync variant separately)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/asset_management

# ---------- AI Provider (interchangeable — config only, see AGENTS.md §4) ----------
AI_PROVIDER=ollama                # ollama | openai | anthropic | gemini
AI_MODEL=qwen2.5                  # default local model (e.g. qwen2.5 / llama3.1)
AI_EMBEDDING_MODEL=nomic-embed-text
AI_REQUEST_TIMEOUT_SECONDS=120

# Ollama (default local inference hub)
OLLAMA_BASE_URL=http://localhost:11434

# Cloud fallbacks (leave blank unless AI_PROVIDER is set to one of these)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ---------- MCP Servers (see AGENTS.md §5) ----------
# AlphaVantage — market data & fundamentals (FREE TIER ONLY: heavily rate-limited)
ALPHAVANTAGE_API_KEY=
ALPHAVANTAGE_MCP_URL=
# Read-through cache: how long persisted quotes/fundamentals stay "fresh" (seconds)
MARKETDATA_CACHE_TTL_SECONDS=86400
# SEC EDGAR — regulatory filings (SEC requires a descriptive User-Agent)
SEC_EDGAR_USER_AGENT=asset-management/0.1 (contact@example.com)
SEC_EDGAR_MCP_URL=
# Filesystem / Browser MCP local endpoints
FILESYSTEM_MCP_URL=
BROWSER_MCP_URL=

# ---------- Currency / FX (USD now, INR next — build currency-aware) ----------
BASE_CURRENCY=USD
SUPPORTED_CURRENCIES=USD          # extend to: USD,INR when INR is enabled
# Free FX rate source (leave blank to use a free/no-key provider)
FX_PROVIDER=
FX_API_KEY=
FX_CACHE_TTL_SECONDS=86400

# ---------- Document ingestion ----------
UPLOAD_DIR=./storage/uploads
MAX_UPLOAD_MB=50

# ---------- News / Macro streaming ----------
NEWS_POLL_INTERVAL_SECONDS=300
NEWS_RSS_FEEDS=                    # comma-separated RSS URLs (optional)

